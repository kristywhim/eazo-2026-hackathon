# ══════════════════════════════════════════════════════════════════
# EAZO Hackathon 2026 — Environment Variables
# Copy to .env.local for local dev; set in Vercel dashboard for prod
# ══════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...              # safe to expose to frontend
SUPABASE_SERVICE_KEY=eyJ...           # ⚠️ SECRET — backend only, never expose

# ── Eazo Platform API ─────────────────────────────────────────────
# ⚠️  PENDING: Need from Eazo team
EAZO_API_BASE=https://api.eazo.com    # base URL for team data endpoint
EAZO_API_KEY=                         # API key / bearer token for Eazo API
EAZO_JWT_SECRET=                      # secret or public key for verifying user auth tokens

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_SECRET=HACKATHON_ADMIN_2026     # used to trigger finalist calculation + team sync
